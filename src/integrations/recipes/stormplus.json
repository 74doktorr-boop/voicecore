{
  "id": "stormplus",
  "name": "StormPlus (LN Deter) — cita previa psicotécnico (formulario público)",
  "_meta": {
    "web": "https://stormplus.lndeter.es/citapreviaonline/{slug}  (público, sin login, sin CAPTCHA)",
    "ejemplo_osakin": "https://stormplus.lndeter.es/citapreviaonline/osakin",
    "tecnologia": "ASP.NET MVC. Form #frmCitaPreviaOnline, anti-CSRF __RequestVerificationToken (lo gestiona el navegador al rellenar el form real). IdGrupoCentros=701 (Osakin), Provincia Gipuzkoa=20.",
    "config_por_negocio": ["org.stormPublicUrl"],
    "datos_entrada": [
      "appt.centro (etiqueta del centro/sede)",
      "appt.tipoPermiso (etiqueta del permiso, p.ej. 'Permiso B - Conducción')",
      "appt.tipoTramite (etiqueta, p.ej. 'Renovación')",
      "appt.date (dd/mm/aaaa)", "appt.time (HH:MM)",
      "patient.dni", "patient.nombre", "patient.apellido1", "patient.apellido2",
      "patient.email", "patient.phone"
    ],
    "notas": [
      "Selects encadenados por AJAX (provincia→centro, tipo→trámite/permiso, fecha→horas): hay waitFor/sleep entre pasos.",
      "El día/hora pueden requerir clic en calendario/grid en vez de escribir; hay selectores candidatos. Si falla, fallback humano.",
      "Conecta con la DGT: exactitud máxima. Es el 10%/lo menos crítico → 2ª prioridad tras Organízate."
    ],
    "estado": "Selectores REALES extraídos del formulario público. Pendiente: validar slot-picking (calendario) contra el comportamiento en vivo y el mapeo de etiquetas de permiso/trámite por centro."
  },
  "steps": [
    { "action": "goto", "url": "{{org.stormPublicUrl}}" },
    { "action": "waitFor", "selectorCandidates": ["#frmCitaPreviaOnline"] },

    { "action": "select", "optional": true, "selectorCandidates": ["#IdProvinciaCentro"], "value": "Gipuzkoa" },
    { "action": "sleep", "ms": 800 },
    { "action": "select", "optional": true, "selectorCandidates": ["#CmbCentro", "select[name=IdCentro]"], "value": "{{appt.centro}}" },
    { "action": "sleep", "ms": 800 },

    { "action": "click", "optional": true, "selectorCandidates": ["#ChkTipoReconocimiento0"] },
    { "action": "select", "optional": true, "selectorCandidates": ["select[name$='IdTipoTramite']"], "value": "{{appt.tipoTramite}}" },
    { "action": "select", "optional": true, "selectorCandidates": ["select[name$='IdTipoPermisoReconocimiento']"], "value": "{{appt.tipoPermiso}}" },
    { "action": "sleep", "ms": 800 },

    { "action": "fill", "selectorCandidates": ["#Fecha"], "value": "{{appt.date}}" },
    { "action": "sleep", "ms": 800 },
    { "action": "fill", "optional": true, "selectorCandidates": ["#HoraInicio"], "value": "{{appt.time}}" },
    { "action": "click", "optional": true, "selectorCandidates": ["button:has-text('{{appt.time}}')", "[data-hora='{{appt.time}}']", ".hora-libre:has-text('{{appt.time}}')"] },

    { "action": "fill", "selectorCandidates": ["#Nif"], "value": "{{patient.dni}}" },
    { "action": "fill", "selectorCandidates": ["#Nombre"], "value": "{{patient.nombre}}" },
    { "action": "fill", "selectorCandidates": ["#Apellido1"], "value": "{{patient.apellido1}}" },
    { "action": "fill", "optional": true, "selectorCandidates": ["#Apellido2"], "value": "{{patient.apellido2}}" },
    { "action": "fill", "optional": true, "selectorCandidates": ["#Email"], "value": "{{patient.email}}" },
    { "action": "fill", "selectorCandidates": ["#txtTelefonoMovil", "input[name=TelefonoMovil]"], "value": "{{patient.phone}}" },

    { "action": "click", "selectorCandidates": ["#ChkAceptoCondiciones", "label[for=ChkAceptoCondiciones]"] },
    { "action": "screenshot", "name": "stormplus-antes-de-enviar" },
    { "action": "click", "skipOnDryRun": true, "selectorCandidates": ["#BtnSolicitarCitaPrevia", "button:has-text('Solicitar Cita Previa')"] },
    { "action": "sleep", "skipOnDryRun": true, "ms": 1200 },
    { "action": "expectText", "skipOnDryRun": true, "anyOf": ["cita ha sido", "solicitud", "confirmada", "hemos recibido", "registrada", "gracias", "correctamente"] },
    { "action": "readText", "skipOnDryRun": true, "optional": true, "selectorCandidates": [".alert-success", "#mensaje", ".confirmacion"], "saveAs": "confirmacion" },
    { "action": "screenshot", "skipOnDryRun": true, "name": "stormplus-confirmacion" }
  ]
}
