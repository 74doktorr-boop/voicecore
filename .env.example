# ============================================
# VoiceCore — Environment Variables
# ============================================

# ─── Server ───
PORT=3001
PUBLIC_URL=https://your-domain.com
API_KEY=voicecore-dev
DASHBOARD_PASSWORD=admin

# ─── STT Providers ───
DEEPGRAM_API_KEY=your_deepgram_key
ASSEMBLYAI_API_KEY=your_assemblyai_key

# ─── LLM Providers ───
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key
ANTHROPIC_API_KEY=your_anthropic_key

# ─── TTS Providers ───
ELEVENLABS_API_KEY=your_elevenlabs_key
CARTESIA_API_KEY=your_cartesia_key
GOOGLE_TTS_API_KEY=your_google_tts_key

# ─── Local TTS (XTTS v2 on RTX 4090) ───
# Run tts_server.py on the GPU machine and set the URL here.
# Leave empty to disable. For local dev: http://localhost:8000
# For remote 4090: http://192.168.X.X:8000 or via tunnel
LOCAL_TTS_URL=http://localhost:8000

# ─── Telephony: Twilio ───
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+34XXXXXXXXX

# ─── Telephony: Vonage (Voice API) ───
# Obtener en: dashboard.nexmo.com/applications
# Answer URL:  https://nodeflow.es/vonage/answer
# Event URL:   https://nodeflow.es/vonage/event
# WebSocket:   wss://nodeflow.es/vonage-stream
VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret
VONAGE_APPLICATION_ID=your_vonage_app_id
VONAGE_PHONE_NUMBER=+34XXXXXXXXX
# Private key content (or path to file)
# VONAGE_PRIVATE_KEY_PATH=./vonage_private.key

# ─── Demo standalone (DEMO-NODEFLOW.html) ───
# Passphrase que el equipo introduce en el campo "Token de acceso" de la demo.
# No es un API key — es un simple portón para la demo pública. Generar con:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DEMO_TOKEN=nodeflow-demo-changeme

# ─── Webhooks ───
WEBHOOK_URL=https://your-webhook-endpoint.com

# ─── Database (Supabase) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key
# REDIS_URL=redis://localhost:6379

# ─── Billing (Stripe) ───
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx          # Obtener en: dashboard.stripe.com/webhooks
# Payment Link IDs (ya configurados):
# Negocio €49: price_1Ta2jHJA7wUpVWZF9NYHYPMO
# Pro €99:     price_1Ta2jIJA7wUpVWZFvllv3zOY

# ─── Email (notificaciones y bienvenida) ───
# Resend — https://resend.com (gratis hasta 3.000 emails/mes)
RESEND_API_KEY=re_xxx
NOTIFY_EMAIL=unai@nodeflow.es

# ─── Storage ───
# S3_BUCKET=voicecore-recordings
# S3_REGION=eu-west-1
# S3_ACCESS_KEY=xxx
# S3_SECRET_KEY=xxx
