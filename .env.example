# ============================================
# VoiceCore — Environment Variables
# ============================================

# ─── Server ───
PORT=3001
PUBLIC_URL=https://your-domain.com
API_KEY=voicecore-dev
DASHBOARD_PASSWORD=admin

# ─── STT Providers ───
DEEPGRAM_API_KEY=your_deepgram_key
ASSEMBLYAI_API_KEY=your_assemblyai_key

# ─── LLM Providers ───
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key
ANTHROPIC_API_KEY=your_anthropic_key

# ─── TTS Providers ───
# Azure Neural TTS — castellano (Elvira/Álvaro), coste bajísimo → proveedor por
# defecto del plan de 49€ (máximo margen). Devuelve mulaw 8kHz directo.
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=westeurope
ELEVENLABS_API_KEY=your_elevenlabs_key
CARTESIA_API_KEY=your_cartesia_key
GOOGLE_TTS_API_KEY=your_google_tts_key

# ─── Local TTS (XTTS v2 on RTX 4090) ───
# Run tts_server.py on the GPU machine and set the URL here.
# Leave empty to disable. For local dev: http://localhost:8000
# For remote 4090: http://192.168.X.X:8000 or via tunnel
LOCAL_TTS_URL=http://localhost:8000

# ─── Telephony: Telnyx (voz IA, +34 946 91 02 75 Bizkaia) ───
# Obtener en: portal.telnyx.com
# Webhook URL: https://nodeflow.es/telnyx/answer
# WebSocket:   wss://nodeflow.es/telnyx-stream
TELNYX_API_KEY=KEY0_your_telnyx_key
TELNYX_PHONE_NUMBER=+34946910275
TELNYX_APP_ID=your_telnyx_app_id

# ─── Telephony: Vonage (Voice API) ───
# Obtener en: dashboard.nexmo.com/applications
# Answer URL:  https://nodeflow.es/vonage/answer
# Event URL:   https://nodeflow.es/vonage/event
# WebSocket:   wss://nodeflow.es/vonage-stream
VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret
VONAGE_APPLICATION_ID=your_vonage_app_id
VONAGE_PHONE_NUMBER=+34XXXXXXXXX
# Private key content (or path to file)
# VONAGE_PRIVATE_KEY_PATH=./vonage_private.key

# ─── WhatsApp Multi-Tenant (360dialog BSP — Partner) — OPCIONAL / Enterprise ───
# Solo necesario si se ofrece WABA propio por negocio (Fase 2 / tier Enterprise).
# En Fase 1 (número compartido NodeFlow) dejar vacío — usar WA_PHONE_NUMBER_ID.
# Obtener en: app.360dialog.io → Settings → Partner API
# NOTA: 360dialog cobra ~€50/mes por canal WABA — incompatible con plan €49.
# DIALOG360_PARTNER_TOKEN=your_partner_token
# DIALOG360_PARTNER_ID=your_partner_id

# ─── Cifrado de credenciales WA en Supabase ───
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Debe ser exactamente 64 caracteres hexadecimales (= 32 bytes).
ENCRYPTION_KEY=your_64_hex_chars_encryption_key

# ─── WhatsApp Business (Meta Cloud API) ───
# Obtener en: developers.facebook.com/apps → WhatsApp → API Setup
# Webhook URL: https://nodeflow.es/whatsapp/webhook
# Número aprobado: +34 XXX XXX XXX (pendiente aprobación 2026-06-10)
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_meta_access_token
WA_WEBHOOK_VERIFY_TOKEN=nodeflow-wa-webhook
# App Secret de la app de Meta (Settings → Basic → App Secret). Verifica la
# firma X-Hub-Signature-256 de cada webhook. Sin esto el webhook NO valida
# que la petición venga de Meta — configúralo en producción.
WA_APP_SECRET=your_meta_app_secret
# Templates pendientes de aprobación Meta:
#   nodeflow_cita_confirmada  — confirmación de reserva (sin botones)
#   nodeflow_cita_recordatorio — recordatorio 24h antes (botones: CONFIRMAR / CANCELAR)
#   nodeflow_resena           — solicitud de reseña 24h después (botón: Dejar reseña)

# ─── Demo standalone (DEMO-NODEFLOW.html) ───
# Passphrase que el equipo introduce en el campo "Token de acceso" de la demo.
# No es un API key — es un simple portón para la demo pública. Generar con:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DEMO_TOKEN=nodeflow-demo-changeme

# ─── Webhooks ───
WEBHOOK_URL=https://your-webhook-endpoint.com

# ─── Database (Supabase) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key
# REDIS_URL=redis://localhost:6379

# ─── Billing (Stripe) ───
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx          # Obtener en: dashboard.stripe.com/webhooks
# Payment Link IDs (ya configurados):
# Negocio €49: price_1Ta2jHJA7wUpVWZF9NYHYPMO
# Pro €99:     price_1Ta2jIJA7wUpVWZFvllv3zOY

# ─── Email (notificaciones y bienvenida) ───
# Resend — https://resend.com (gratis hasta 3.000 emails/mes)
RESEND_API_KEY=re_xxx
NOTIFY_EMAIL=unai@nodeflow.es

# ─── Auth (Portal magic links + JWT) ───
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_64_chars_min

# ─── Notificaciones WhatsApp a Unai (Callmebot) ───
# Dar de alta en: callmebot.com/blog/free-api-whatsapp-messages/
# OWNER_PHONE es el número personal de Unai (con código país, sin +)
OWNER_PHONE=34666351319
CALLMEBOT_PHONE=34666351319
CALLMEBOT_API_KEY=your_callmebot_api_key

# ─── Google Calendar OAuth (integraciones de clientes) ───
# Crear en: console.cloud.google.com → OAuth 2.0 Client IDs
# Scopes requeridos: https://www.googleapis.com/auth/calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://nodeflow.es/api/integrations/google/callback

# ─── Storage ───
# S3_BUCKET=voicecore-recordings
# S3_REGION=eu-west-1
# S3_ACCESS_KEY=xxx
# S3_SECRET_KEY=xxx
